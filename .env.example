LYNX_APP_NAME=Lynx Candidate Identification System
LYNX_ENV=development
LYNX_HOST=0.0.0.0
LYNX_PORT=8000
LYNX_LOG_LEVEL=INFO

# LLM Reasoning Agent Configuration
# Set to an OpenAI-compatible API key (OpenAI, Anthropic via proxy, etc.)
LYNX_LLM_API_KEY=
LYNX_LLM_MODEL=gpt-4o-mini
LYNX_LLM_API_URL=https://api.openai.com/v1/chat/completions
LYNX_LLM_ENABLED=true
LYNX_LLM_RATE_LIMIT_SECONDS=60
LYNX_LLM_REQUEST_TIMEOUT_SECONDS=15.0
